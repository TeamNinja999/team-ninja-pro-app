{
  "name": "ytdownloader-desktop",
  "version": "1.0.3",
  "description": "Professional YouTube Downloader",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run react:dev\" \"npm run electron:dev\"",
    "react:dev": "vite",
    "electron:dev": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.ytdownloader.app",
    "productName": "YTDownloader",
    "files": [
      "main.js",
      "preload.js",
      "build/**/*",
      "config.json",
      "custom_icon.png"
    ],
    "extraResources": [
      {
        "from": "backend.exe",
        "to": "backend.exe"
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "TeamNinja999",
      "repo": "team-ninja-pro-app"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.2.1",
    "framer-motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}